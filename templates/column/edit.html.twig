{% extends 'base.html.twig' %}

{% block title %}Modifier la colonne · {{ project.name }}{% endblock %}

{% block body %}
    <div class="breadcrumb">
        <a href="{{ path('app_project_index') }}">Projets</a> /
        <a href="{{ path('app_project_show', {id: project.id}) }}">{{ project.name }}</a> /
        <a href="{{ path('app_column_index', {id: project.id}) }}">Colonnes</a> / Modifier
    </div>
    <div class="page-head"><h1>Modifier la colonne</h1></div>

    <div class="card form-card"><div class="card-body">
        {% include 'column/_form.html.twig' with {
            submit_label: 'Enregistrer',
            cancel_path: path('app_column_index', {id: project.id})
        } %}
    </div></div>
{% endblock %}
