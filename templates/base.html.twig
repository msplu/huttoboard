<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Huttoboard{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.1em%22 font-size=%22104%22>🗂️</text></svg>">
        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        {% block layout %}
            <header class="navbar">
                <a href="{{ path('app_project_index') }}" class="brand">
                    <span class="logo">🗂️</span> Huttoboard
                </a>
                {% if app.user %}
                    <nav>
                        <a href="{{ path('app_project_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_project' or app.request.attributes.get('_route') starts with 'app_ticket' or app.request.attributes.get('_route') starts with 'app_column' ? 'active' }}">Projets</a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_user_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_user' ? 'active' }}">Utilisateurs</a>
                        {% endif %}
                    </nav>
                {% endif %}
                <span class="spacer"></span>
                {% if app.user %}
                    <span class="user">
                        <span class="avatar">{{ app.user.initials }}</span>
                        {{ app.user.fullName }}
                        {% if is_granted('ROLE_ADMIN') %}<span class="tag admin">Admin</span>{% endif %}
                    </span>
                    <a href="{{ path('app_logout') }}" class="btn btn-sm">Déconnexion</a>
                {% endif %}
            </header>

            {% include 'partials/_flashes.html.twig' %}

            <main class="{% block container_class %}container{% endblock %}">
                {% block body %}{% endblock %}
            </main>
        {% endblock %}
    </body>
</html>
