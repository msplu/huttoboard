{% extends 'base.html.twig' %}

{% block title %}Projets · Huttoboard{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Projets</h1>
            <p class="subtitle">{{ projects|length }} projet(s)</p>
        </div>
        <span class="spacer"></span>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_project_new') }}" class="btn btn-primary">＋ Nouveau projet</a>
        {% endif %}
    </div>

    {% if projects is empty %}
        <div class="card"><div class="empty-state">
            <div class="icon">🗂️</div>
            <p>Aucun projet pour le moment.</p>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_project_new') }}" class="btn btn-primary">Créer le premier projet</a>
            {% else %}
                <p>Contactez un administrateur pour créer un projet.</p>
            {% endif %}
        </div></div>
    {% else %}
        <div class="grid">
            {% for project in projects %}
                <a href="{{ path('app_project_show', {id: project.id}) }}" class="card project-card">
                    <div class="card-body" style="display:flex;flex-direction:column;flex:1">
                        <span class="code-chip">{{ project.code }}</span>
                        <h3>{{ project.name }}</h3>
                        <p>{{ project.description|default('Pas de description.')|u.truncate(110, '…') }}</p>
                        <div class="meta">
                            <span>📋 {{ project.columns|length }} colonne(s)</span>
                            <span>🎫 {{ project.ticketCount }} ticket(s)</span>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
